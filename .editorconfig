root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript / JS – 4 spaces
[*.{js,jsx,mjs,cjs,ts,tsx,mts,cts}]
indent_style = space
indent_size = 4
max_line_length = 100

# Vue / HTML / CSS – 2 spaces
[*.{vue,html,css,scss,sass,less,styl}]
indent_style = space
indent_size = 2
max_line_length = 100

